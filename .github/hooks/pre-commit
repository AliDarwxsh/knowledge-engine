#!/usr/bin/env bash
# pre-commit hook — runs sanitize-check.sh on staged files before allowing commit
# Install: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e
set -u

# Colors
if [[ -t 1 ]]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; NC=''
fi

echo ""
echo "Running pre-commit security checks..."
echo ""

# Run sanitize-check on staged files
if bash scripts/sanitize-check.sh --staged; then
  echo -e "${GREEN}✓ Pre-commit checks passed${NC}"
  exit 0
else
  STATUS=$?
  if [[ $STATUS -eq 1 ]]; then
    echo ""
    echo -e "${RED}COMMIT BLOCKED${NC} — high-confidence personal data or secrets detected."
    echo "Fix the flagged issues, then commit again."
    exit 1
  elif [[ $STATUS -eq 2 ]]; then
    echo ""
    echo -e "${YELLOW}WARNING${NC} — low-confidence findings. Review recommended."
    echo "To bypass (not recommended): git commit --no-verify"
    # Don't block on warnings, but make them visible
    exit 0
  fi
  exit $STATUS
fi
