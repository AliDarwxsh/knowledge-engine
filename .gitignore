# Knowledge Engine — .gitignore
# Public open-source repo. No personal data, no credentials, no build artifacts.

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Obsidian
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache.json
.obsidian/hotkeys.json
.obsidian/plugins/
.obsidian/themes/
.obsidian/snippets/

# Environment & credentials
.env
.env.*
*.local
.envrc

# Node / npm
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
dist/
build/
out/

# Hermes runtime files
.hermes/
hermes.lock

# Agent / tooling runtime state (NEVER ship — contains local paths, session IDs, usage logs)
.claude/
.cursor/
.kiro/
.smart-env/
.obsidian/

# Personal vault content that must never be committed to the public template.
# The repo ships folder scaffolds (README.md) only — never real captured notes.
vault/00 Inbox/*
!vault/00 Inbox/README.md
!vault/00 Inbox/_imported/
!vault/00 Inbox/_processed/
!vault/00 Inbox/_unclassified/
vault/00 Inbox/_imported/*
!vault/00 Inbox/_imported/README.md
vault/00 Inbox/_processed/*
!vault/00 Inbox/_processed/README.md
vault/00 Inbox/_unclassified/*
!vault/00 Inbox/_unclassified/README.md
vault/sources/*
!vault/sources/README.md

# Obsidian Sync conflicts
*.sync-conflict-*

# Archives
*.zip
*.tar.gz
*.rar

# Temp files
*.tmp
*.bak
*.log

# Test coverage / tox
.coverage
.tox/
htmlcov/
.pytest_cache/

# Secrets that might be generated during dev
*.pem
*.cert
*.key
*.p12
*.pfx

# Local environment overrides
.env.local
.env.*.local

# Package manager lock files (only keep one canonical)
# We use uv/pyproject.toml; ignore pip artifacts
pip-wheel-metadata/

# Type checking
.mypy_cache/
.dmypy.json

# Misc
.cache/
.eggs/
